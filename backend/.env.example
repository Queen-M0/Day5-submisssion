APP_NAME=ContextGuard API
APP_ENV=development
AUTH_SECRET=replace-with-a-long-random-secret
AUTH_TOKEN_HOURS=12
DATABASE_URL=mysql+pymysql://contextguard:contextguard@127.0.0.1:3306/ai_moderation?charset=utf8mb4
# Zero-config fallback for quick local checks:
# DATABASE_URL=sqlite:///./contextguard.db
FRONTEND_ORIGINS=http://localhost:5173

# auto: use MiMo when MIMO_API_KEY is set, otherwise use the deterministic mock provider.
# mimo: always attempt MiMo; missing credentials or provider failures safely route content to manual review.
# mock: deterministic local development and regression tests.
AI_PROVIDER=auto
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5
MIMO_SECONDARY_MODEL=mimo-v2.5-pro
# Enable to call both models on every initial moderation request. This increases latency and token usage.
AI_DUAL_REVIEW_ENABLED=false
MIMO_TIMEOUT_SECONDS=30
MIMO_MAX_TOKENS=1800
MIMO_TEMPERATURE=0.1
MIMO_JSON_MODE=true
