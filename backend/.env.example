APP_NAME=ContextGuard API
APP_ENV=development
DATABASE_URL=mysql+pymysql://contextguard:contextguard@127.0.0.1:3306/ai_moderation?charset=utf8mb4
# Zero-config fallback for quick local checks:
# DATABASE_URL=sqlite:///./contextguard.db
FRONTEND_ORIGINS=http://localhost:5173

# AI moderation provider: "mock" (deterministic, offline) or "real" (OpenAI-compatible API)
AI_PROVIDER=mock
AI_API_KEY=
AI_BASE_URL=https://api.xiaomimimo.com/v1
AI_MODEL=mimo-v2.5
AI_PROMPT_VERSION=moderation-v1
AI_RULE_VERSION=community-v1
AI_TIMEOUT=12
AI_TEMPERATURE=0
AI_MAX_TOKENS=900

# Appeal re-review ("counter-argument") agent. Reuses the same API key/base URL.
# Leave AI_APPEAL_MODEL empty to reuse AI_MODEL.
AI_APPEAL_MODEL=
AI_APPEAL_PROMPT_VERSION=appeal-critic-v1
AI_APPEAL_RULE_VERSION=appeal-community-v1
