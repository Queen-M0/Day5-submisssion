APP_NAME=ContextGuard API
APP_ENV=development
AUTH_SECRET=replace-with-a-long-random-secret
AUTH_TOKEN_HOURS=12

DATABASE_URL=mysql+pymysql://contextguard:contextguard@127.0.0.1:3306/ai_moderation?charset=utf8mb4
# Zero-config fallback for quick local checks:
# DATABASE_URL=sqlite:///./contextguard.db
FRONTEND_ORIGINS=http://localhost:5173

# AI provider: "auto" (MiMo when key exists, otherwise mock), "mimo"/"real", or "mock".
AI_PROVIDER=auto
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5
MIMO_SECONDARY_MODEL=mimo-v2.5-pro
AI_DUAL_REVIEW_ENABLED=false
MIMO_TIMEOUT_SECONDS=30
MIMO_MAX_TOKENS=400
MIMO_TEMPERATURE=0.1
MIMO_JSON_MODE=true

# Backward-compatible OpenAI-compatible names used by the earlier local branch.
# If MIMO_API_KEY is empty, AI_API_KEY can also activate the real provider.
AI_API_KEY=
AI_BASE_URL=https://api.xiaomimimo.com/v1
AI_MODEL=mimo-v2.5
AI_PROMPT_VERSION=moderation-v2
AI_RULE_VERSION=community-v1
AI_TIMEOUT=12
AI_TEMPERATURE=0
AI_MAX_TOKENS=900

# Appeal re-review ("counter-argument") agent. Leave AI_APPEAL_MODEL empty to reuse the primary model.
AI_APPEAL_MODEL=
AI_APPEAL_PROMPT_VERSION=appeal-critic-v1
AI_APPEAL_RULE_VERSION=appeal-community-v1
